{
  "name": "brownies-api",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "normalize:product-prices": "node scripts/normalize-product-prices.js",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts src/database/migrations/auto"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.4.8",
    "@nestjs/jwt": "^10.1.1",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@types/cache-manager": "^4.0.6",
    "@types/nodemailer": "^7.0.4",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.9.1",
    "nodemailer": "^7.0.11",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.1.14",
    "resend": "^6.6.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
