# Database Connection
# Supabase pooler example:
# postgres://postgres.<project-ref>:password@aws-1-region.pooler.supabase.com:6543/postgres
DATABASE_URL="postgres://user:password@host:port/database"
SUPABASE_PROJECT_REF=""

# Security
JWT_SECRET="changeme_to_something_secret"
GOOGLE_MAPS_API_KEY=""

# Optional: Set to 'true' if using SSL connection (Render requires this)
DB_SSL=true

# Port (Defaults to 3000)
PORT=3000
